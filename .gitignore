# Vendored external source (installed via uvx; reference only)
vendor/

# Build artifacts (regenerable from scripts/)
outputs/*.blend
outputs/*.blend1
outputs/renders/*.png
outputs/renders/*.exr

# Orchestrator runtime state
orchestrator/locks/*
!orchestrator/locks/.gitkeep
orchestrator/logs/*
!orchestrator/logs/.gitkeep
orchestrator/worktrees/
orchestrator/.runner-*.sh

# Blender backup files everywhere
*.blend1
*.blend2

# Editor / OS junk
.DS_Store
*.swp
*~

# Python cache (in case scripts/ accumulates any)
__pycache__/
*.pyc
.pytest_cache/

# Tool caches
.uv/
.venv/
build/
dist/
*.egg-info/
